rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated as an admin
    // Note: Since you're using Firebase Admin SDK on the backend, backend operations 
    // bypass these rules. These rules apply ONLY to client-side SDK requests.
    // We deny almost everything from the client to enforce going through the Flask backend.

    match /{document=**} {
      allow read, write: if false; // Default deny
    }

    // Allow client SDK to read the freeze status (required for the real-time overlay)
    match /auction_state/freeze_status {
      allow read: if true;
    }

    // In a fully secure setup, we would verify Firebase Auth tokens, but since
    // the app uses Flask session cookies for auth, we can't reliably verify them
    // in Firestore Rules. 
    // Therefore, all other interactions MUST happen via the Flask backend 
    // (which uses the Admin SDK and bypasses these rules).
  }
}
